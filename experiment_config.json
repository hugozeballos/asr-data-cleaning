{
    "run_name": "CVClean_Wlarge",
    
    "dataset_name": "HugoZeballos/original-audio-dataset-with-inferencesofwhysper-and-metrics",
    
    "model_name": "openai/whisper-large-v3-turbo",

    "cer_records_file": "experiments/CVClean_Wlarge/cer_records.json",
    "cer_complete_suffix": "_complete",
    
    "mode": "full",
    "filtering_strategy": "threshold",
    "filtering_threshold": 0.1,
    
    "output_dir": "experiments/CVClean_Wlarge/checkpoints",
    "json_output": "experiments/CVClean_Wlarge/removed_CVClean_Wlarge_threshold_01_ids.json",
    "mlflow_experiment": "CVClean_Wlarge",
    
    "batch_size": 2,
    "epochs": 1,
    "learning_rate": 5e-5,
    
    "gpus": 1,
    "gpu_type": "titan_rtx",
    "partition": "ialab-high",
    "ntasks": 1,
    "cpus_per_task": 4
  }